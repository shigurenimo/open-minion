{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "paths": {
      "@/*": ["./cli/src/*"],
      "@lib/*": ["./lib/*"]
    }
  },
  "include": ["cli/src", "lib"]
}
