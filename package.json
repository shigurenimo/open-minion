{
  "name": "@shigureni/minion",
  "version": "0.5.0",
  "description": "Desktop pet that reacts to your Claude Code session activity",
  "keywords": [
    "claude-code",
    "cli",
    "desktop-pet",
    "macos"
  ],
  "license": "MIT",
  "author": "shigurenimo",
  "bin": {
    "minion": "dist/cli/src/index.mjs"
  },
  "files": [
    "dist",
    "swift",
    "!swift/.build"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.mts",
      "default": "./dist/lib/index.mjs"
    },
    "./app": {
      "types": "./dist/lib/app.d.mts",
      "default": "./dist/lib/app.mjs"
    },
    "./boundaries": {
      "types": "./dist/lib/boundaries.d.mts",
      "default": "./dist/lib/boundaries.mjs"
    },
    "./cli": {
      "types": "./dist/cli/src/cli.d.mts",
      "default": "./dist/cli/src/cli.mjs"
    },
    "./collection": {
      "types": "./dist/lib/collection.d.mts",
      "default": "./dist/lib/collection.mjs"
    },
    "./config": {
      "types": "./dist/lib/config.d.mts",
      "default": "./dist/lib/config.mjs"
    },
    "./discord": {
      "types": "./dist/lib/discord.d.mts",
      "default": "./dist/lib/discord.mjs"
    },
    "./gateway": {
      "types": "./dist/lib/gateway.d.mts",
      "default": "./dist/lib/gateway.mjs"
    },
    "./stats": {
      "types": "./dist/lib/stats.d.mts",
      "default": "./dist/lib/stats.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "prepack": "npm run build",
    "check": "vp check",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "test": "vp test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.8",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@voidzero-dev/vite-plus-core": "^0.2.2",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
